{
  "matrix": {
    "homeserver": "https://matrix.chenyun.org",
    "user_id": "@hanyan:matrix.chenyun.org",
    "password": "CHANGE_ME_OR_SET_HANYAN_MATRIX_PASSWORD_ENV",
    "device_name": "HanyanChat"
  },
  "llm": {
    "base_url": "http://localhost:11434",
    "model": "qwen3.5:9b",
    "temperature": 0.7,
    "timeout": 60,
    "api_key": "",
    "think": false
  },
  "tts": {
    "enabled": true,
    "provider": "saes",
    "base_url": "http://127.0.0.1:9100",
    "endpoint": "/hanyan/stream",
    "timeout": 30,
    "engine": "gptsovits",
    "api_key": "",
    "model": "FunAudioLLM/CosyVoice2-0.5B",
    "voice": "FunAudioLLM/CosyVoice2-0.5B:anna",
    "speed": 1.0,
    "max_files": 200,
    "max_age_days": 7
  },
  "stt": {
    "enabled": true,
    "model": "mlx-community/whisper-large-v3-turbo",
    "language": "zh"
  },
  "proactive": {
    "interval_minutes": 30,
    "quiet_start": "23:00",
    "quiet_end": "07:00"
  },
  "memory": {
    "max_entries": 50,
    "storage_dir": "./data/memories",
    "promote_threshold": 30,
    "core_memory_max": 50,
    "use_llm_summary": true
  },
  "character": {
    "prompts_dir": "./prompts",
    "default_character": "小月",
    "user_map": {
      "@friend:matrix.chenyun.org": "角色2"
