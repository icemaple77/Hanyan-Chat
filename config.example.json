  },
  "commands": {
    "enabled": true,
    "prefix": "/"
  },
  "webui": {
    "enabled": false,
    "host": "127.0.0.1",
    "port": 5001,
    "username": "admin",
    "password": "CHANGE_ME_OR_SET_HANYAN_WEBUI_PASSWORD_ENV",
    "secret_key": "CHANGE_ME_OR_SET_HANYAN_WEBUI_SECRET_ENV"
