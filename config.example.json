{
  "matrix": {
    "homeserver": "https://matrix.chenyun.org",
    "user_id": "@hanyan:matrix.chenyun.org",
    "password": "CHANGE_ME_OR_SET_HANYAN_MATRIX_PASSWORD_ENV",
    "device_name": "HanyanChat"
  },
  "llm": {
    "base_url": "http://localhost:11434",
    "model": "qwen3.5:9b",
    "temperature": 0.7,
    "timeout": 60,
    "api_key": "",
    "think": false,
    "cloud": {
      "base_url": "",
      "api_key": "",
      "model": "deepseek-chat",
      "timeout": 60,
      "_说明": "云端模型(OpenAI兼容,如DeepSeek)。base_url留空=纯本地。用途分配见 llm.route(WebUI「模型」页可视化编辑)"
    },
    "route": {
      "chat": "local",
      "tools": "local",
      "reflection": "local"
    }
  },
  "tts": {
    "enabled": true,
    "provider": "saes",
    "base_url": "http://127.0.0.1:9100",
    "endpoint": "/hanyan/stream",
    "timeout": 30,
    "engine": "gptsovits",
    "api_key": "",
    "model": "FunAudioLLM/CosyVoice2-0.5B",
    "voice": "FunAudioLLM/CosyVoice2-0.5B:anna",
    "speed": 1.0,
    "max_files": 200,
    "max_age_days": 7
  },
  "stt": {
    "enabled": true,
    "model": "mlx-community/whisper-large-v3-turbo",
    "language": "zh"
  },
  "proactive": {
    "interval_minutes": 30,
    "quiet_start": "23:00",
    "quiet_end": "07:00",
    "max_per_day": 24
  },
  "memory": {
    "max_entries": 50,
    "storage_dir": "./data/memories",
    "promote_threshold": 30,
    "core_memory_max": 50,
    "use_llm_summary": true
  },
  "character": {
    "prompts_dir": "./prompts",
    "default_character": "小月",
    "user_map": {
      "@friend:matrix.chenyun.org": "角色2"
    }
  },
  "link_fetch": {
    "enabled": true,
    "timeout": 10,
    "max_length": 2000,
    "user_agent": "Mozilla/5.0 (compatible; HanyanChat/1.0)"
  },
  "commands": {
    "enabled": true,
    "prefix": "/"
  },
  "webui": {
    "enabled": false,
    "host": "127.0.0.1",
    "port": 5001,
    "username": "admin",
    "password": "CHANGE_ME_OR_SET_HANYAN_WEBUI_PASSWORD_ENV",
    "secret_key": "CHANGE_ME_OR_SET_HANYAN_WEBUI_SECRET_ENV",
    "chat_user_id": "",
    "_说明": "chat_user_id=网页聊天绑定的Matrix用户(留空自动取最活跃会话);enabled=true时WebUI随bot内嵌启动,网页聊天与Matrix共用会话"
  },
  "tools": {
    "enabled": true,
    "searxng_url": "",
    "max_calls_per_turn": 3,
    "max_image_mb": 5,
    "download_max_age_days": 7,
    "_说明": "searxng_url留空用DuckDuckGo;配自建SearXNG后搜索质量更好且支持图片搜索"
  },
  "evolution": {
    "enabled": true,
    "reflect_hour": 4,
    "_说明": "每日自我反思(成长档案+兴趣演化),reflect_hour=过了几点后执行"
  },
  "fs": {
    "enabled": true,
    "workspace_dir": "",
    "read_roots": [
      "~"
    ],
    "max_read_kb": 256,
    "approval_timeout_min": 15,
    "_说明": "她的文件权限:workspace_dir(默认data/workspace)内自由读写删;read_roots内只读;工作区外写/删需聊天里/批准。敏感路径(.ssh/密钥/token等)硬黑名单"
  },
  "agent": {
    "max_steps": 5,
    "_说明": "多步任务执行:步数上限;每步工具调用沿用tools.max_calls_per_turn;同时只跑一个任务"
  }
}
